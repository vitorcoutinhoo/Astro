---
import '../styles/global.css';
import BgBlobs from '../components/BgBlobs.astro';

interface Props {
  title?: string;
}

const { title = 'Vitor — Developer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="is-loading">
  <div class="page-wrapper">
    <BgBlobs />
    <div class="page-content">
      <slot />
    </div>
  </div>
</body>
</html>

<style>
  .page-wrapper {
    position: relative;
  }

  .page-content {
    position: relative;
    z-index: 1;
  }
</style>
