---
import { projects } from '../data/projects.ts';
---

<section class="work" id="work">
  <p class="section-label">Trabalhos selecionados</p>

  <div class="projects-list">
    {projects.map(project => (
      <a class="project-item" href={project.href}>
        <span class="project-num">{project.num}</span>
        <div class="project-info">
          <div class="project-name">{project.name}</div>
          <div class="project-desc">{project.desc}</div>
        </div>
        <div class="project-meta">
          <div class="project-tags">
            {project.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
          <span class="project-arrow">→</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .work { border-top: 1px solid var(--border); }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .project-item {
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    gap: 2rem;
    padding: 2rem 2.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-item:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(232, 92, 42, 0.1);
    transform: translateX(6px);
  }

  .project-num {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--muted);
    padding-top: 0.25rem;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .project-name {
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    transition: color 0.2s;
  }

  .project-item:hover .project-name { color: var(--accent); }

  .project-desc {
    font-size: 1rem;
    color: var(--body);
    max-width: 48ch;
    line-height: 1.65;
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-tags {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    align-items: flex-end;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--body);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s;
  }

  .project-item:hover .tag {
    border-color: var(--accent);
    color: var(--accent);
  }

  .project-arrow {
    font-size: 1.125rem;
    color: var(--muted);
    transition: color 0.2s, transform 0.3s;
    line-height: 1;
  }

  .project-item:hover .project-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .project-item { grid-template-columns: 3rem 1fr; }
    .project-meta { display: none; }
  }
</style>
